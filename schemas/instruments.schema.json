{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fix-message-builder/instruments.schema.json",
  "title": "FIX Message Builder instrument database (JSON form)",
  "description": "User-supplied instrument universe (docs/BRIEF.md §3.10). CSV is equally supported with prefix-mapped columns: key, name, scheme:<scheme>, attr:<name>. Never ship real instrument data in a public repo.",
  "type": "object",
  "required": ["instruments"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "instruments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "schemes": {
            "type": "object",
            "description": "Identifier values keyed by scheme: isin, exchangeSymbol, ric, custom:<name>, ... Schemes are profile-declared, not engine-hardcoded.",
            "additionalProperties": { "type": "string" }
          },
          "attrs": {
            "type": "object",
            "description": "Typed attributes: securityType, currency, mic, cfiCode, maturityMonthYear (YYYYMM | YYYYMMDD | YYYYMMwN), maturityDate, strikePrice, putOrCall, optAttribute, contractMultiplier, underlying (record key), plus arbitrary extras.",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "strategies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "legs"],
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "strategyType": {
            "type": "string",
            "description": "Maps to SecuritySubType(762) where used"
          },
          "schemes": {
            "type": "object",
            "description": "Venue-listed strategies carry their own identifiers",
            "additionalProperties": { "type": "string" }
          },
          "attrs": { "type": "object", "additionalProperties": { "type": "string" } },
          "legs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["instrument"],
              "properties": {
                "instrument": { "type": "string", "description": "Key of an instrument record" },
                "ratioQty": { "type": "string" },
                "side": { "type": "string" },
                "price": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
